{
  "appId": "com.expense.tracker",
  "productName": "记账小助手",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources",
      "to": "resources"
    }
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.finance",
    "icon": "resources/icon.icns"
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "resources/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Finance"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "asar": true,
  "asarUnpack": [
    "node_modules/sql.js/**/*"
  ]
}

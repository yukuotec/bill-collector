{
  "name": "expense-tracker",
  "version": "1.0.0",
  "description": "记账小助手 - Personal expense tracker",
  "main": "dist/main/index.js",
  "bin": {
    "expense-cli": "dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.main.json",
    "test:parsers": "npm run build:electron && node --test tests/parsers.test.js",
    "test:react": "node --test tests/react.test.js",
    "test:database": "node --test tests/database.test.js",
    "test:e2e": "npx playwright test e2e/",
    "test:e2e:ui": "npx playwright test e2e/ --ui",
    "test:e2e:headed": "npx playwright test e2e/ --headed",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.0",
    "commander": "^5.1.0",
    "imap": "^0.8.19",
    "mailparser": "^3.9.3",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "sql.js": "^1.11.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^28.1.0",
    "@playwright/test": "^1.40.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^1.2.0"
  },
  "author": "",
  "license": "MIT"
}
